{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(app_http_requests_total[1m])) by (path)", "legendFormat": "{{path}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}" }
      ]
    },
    {
      "type": "piechart",
      "title": "Agent routing distribution",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(increase(agent_route_total[1h])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM p95 latency by provider (s)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(llm_call_duration_seconds_bucket[5m])) by (le, provider))", "legendFormat": "{{provider}}" }
      ]
    },
    {
      "type": "stat",
      "title": "LLM fallbacks (1h)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "sum(increase(llm_fallback_total[1h]))", "legendFormat": "fallbacks" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Guardrail blocks by rule",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(guardrail_block_total[1h])) by (rule)", "legendFormat": "{{rule}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hybrid retrieval p95 latency (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(retrieval_duration_seconds_bucket[5m])) by (le))", "legendFormat": "hybrid" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["career-copilot"],
  "title": "Career Copilot Agent",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "10s"
}
